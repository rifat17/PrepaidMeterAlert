# Logging
MA_LOG_LEVEL=info          # debug | info | warn | error
MA_LOG_FORMAT=json         # json | text

# Database
MA_DATABASE_URL=postgres://myuser:mysecretpassword@localhost:5433/meterbot?sslmode=disable

# Telegram
MA_TELEGRAM_TOKEN=         # required — get from @BotFather
MA_TELEGRAM_RATE_LIMIT=30  # max messages/s (Telegram hard limit is 30)

# DESCO datasource
MA_DESCO_BASE_PATH=https://prepaid.desco.org.bd
MA_DESCO_TIMEOUT=10s
MA_DESCO_RETRY=3
MA_DESCO_RETRY_DELAY=1s
MA_DESCO_RATE_LIMIT=5      # max requests/s to DESCO API

# OpenTelemetry
MA_OTEL_ENABLED=true
MA_OTLP_ENDPOINT=localhost:4317
MA_SERVICE_NAME=meterbot
MA_ENVIRONMENT=development  # development | production

# NESCO datasource
MA_NESCO_BASE_PATH=https://customer.nesco.gov.bd
MA_NESCO_TIMEOUT=10s
MA_NESCO_RETRY=3
MA_NESCO_RETRY_DELAY=1s
MA_NESCO_RATE_LIMIT=2